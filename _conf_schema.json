{
    "keywords": {
        "description": "触发关键词",
        "type": "list",
        "items": {"type": "string"},
        "default": ["随机视频", "来点视频", "随机B站"]
    },
    "send_type": {
        "description": "发送形式",
        "type": "string",
        "options": ["image", "text"],
        "labels": ["图文消息", "纯文本"],
        "default": "image"
    },
    "show_processing": {
        "description": "显示「正在搬运」提示",
        "type": "bool",
        "default": true
    },
    "max_retries": {
        "description": "API请求最大重试次数",
        "type": "int",
        "default": 3
    },
    "max_video_age_days": {
        "description": "视频最大发布天数限制 (0为不限制)",
        "type": "int",
        "default": 7
    },
    "credential": {
        "description": "B站登录凭证",
        "type": "dict",
        "hint": "用于规避风控，提高请求稳定性",
        "props": {
            "sessdata": {"type": "string", "description": "SESSDATA Cookie值", "default": ""},
            "bili_jct": {"type": "string", "description": "bili_jct Cookie值", "default": ""},
            "buvid3": {"type": "string", "description": "buvid3 Cookie值", "default": ""}
        }
    }
}
