{
    "use_whitelist_mode": {
        "description": "使用白名单模式（否则为黑名单模式）",
        "type": "bool",
        "default": false
    },
    "whitelist_groups": {
        "description": "白名单群号列表",
        "type": "list",
        "items": { "type": "string" },
        "default": []
    },
    "blacklist_groups": {
        "description": "黑名单群号列表",
        "type": "list",
        "items": { "type": "string" },
        "default": []
    },
    "scan_interval": {
        "description": "定时自动推送间隔（秒）",
        "type": "int",
        "default": 3600
    },
    "auto_start": {
        "description": "插件启动时自动开启定时推送",
        "type": "bool",
        "default": true
    },
    "keywords": {
        "description": "触发推送的关键词列表",
        "type": "list",
        "items": { "type": "string" },
        "default": ["随机视频", "来点视频", "B站视频"]
    },
    "keyword_cooldown_seconds": {
        "description": "关键词触发冷却时间（秒）",
        "type": "int",
        "default": 600
    }
}
